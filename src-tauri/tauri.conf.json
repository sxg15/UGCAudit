{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UGCAudit",
  "version": "0.1.0",
  "identifier": "com.ugcaudit.portable",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run web:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../Publish/UGCAudit/web-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "UGCAudit",
        "create": false,
        "width": 1280,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
